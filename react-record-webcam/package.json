{
  "name": "react-record-webcam",
  "description": "React hook for webcam and audio recording with multi-device support, quality presets, and full TypeScript types",
  "version": "2.0.1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelweckstrom/react-record-webcam"
  },
  "homepage": "https://github.com/samuelweckstrom/react-record-webcam#readme",
  "bugs": {
    "url": "https://github.com/samuelweckstrom/react-record-webcam/issues"
  },
  "author": "Samuel Weckström",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "keywords": [
    "react",
    "webcam",
    "camera",
    "record",
    "recording",
    "video",
    "audio",
    "media",
    "mediarecorder",
    "hook",
    "react-hook",
    "multi-device",
    "concurrent",
    "screenshot",
    "capture",
    "stream",
    "typescript"
  ],
  "sideEffects": false,
  "type": "module"
}
