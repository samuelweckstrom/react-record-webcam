{
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "demo": "pnpm --filter demo dev",
    "package": "pnpm --filter react-record-webcam dev",
    "build:demo": "pnpm --filter demo build",
    "build:package": "pnpm --filter react-record-webcam build",
    "build:all": "pnpm run build:package && pnpm run build:demo",
    "test": "jest",
    "test:clearCache": "jest --clearCache"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
